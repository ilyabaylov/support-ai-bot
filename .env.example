# Токен бота от @BotFather
BOT_TOKEN=123456:PASTE_YOUR_TOKEN

# Ключ Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ID администраторов через запятую (свой узнать у @userinfobot).
# Эти люди видят админ-панель: статистику, обращения, пересбор базы.
ADMIN_IDS=

# Куда слать обращения к администратору. Если пусто — летят первому из ADMIN_IDS.
OPERATOR_CHAT_ID=

# Порог уверенности: если лучший кусок базы ниже — зовём человека (0..1)
SIM_THRESHOLD=0.62

# Сколько кусков базы подмешивать в ответ
TOP_K=4

# Модели Gemini
CHAT_MODEL=gemini-2.0-flash
EMBED_MODEL=text-embedding-004
